# Copy to keystore.properties in the project root (gitignored) and fill in values.
# Generate a keystore once, e.g.:
#   mkdir -p keystore
#   keytool -genkeypair -v -storetype PKCS12 -keystore keystore/release.jks -alias YOUR_ALIAS \
#     -keyalg RSA -keysize 2048 -validity 10000

storePassword=
keyPassword=
keyAlias=
storeFile=keystore/release.jks
