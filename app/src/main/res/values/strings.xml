    <string name="hid_transport_summary_keyboard_ready">Keyboard HID ready</string>
    <string name="hid_transport_summary_full_ready">Keyboard + media HID ready</string>
    <string name="hid_transport_summary_error">HID error</string>
    <string name="hid_transport_detail_default">Real output to a tethered PC needs a USB gadget with HID enabled (root, custom kernel, or configfs). Retail phones usually expose MTP/ADB only — DeckBridge still runs; watch [HID] and [ACTION] in Logcat.</string>
    <string name="hid_transport_paths">Keyboard: %1$s · Consumer: %2$s</string>
    <string name="hid_transport_nodes_line">Probe: keyboard %1$s · consumer %2$s</string>
    <string name="hid_node_state_missing">missing</string>
    <string name="hid_node_state_writable">writable</string>
    <string name="hid_node_state_present_blocked">present, not writable</string>
    <string name="hid_transport_last_error">Last error: %s</string>
    <string name="hid_log_diagnose_no_nodes">Diagnosis: no /dev/hidg* nodes. A USB cable to Windows (charging/MTP/ADB) does not make this phone a HID keyboard. The PC will not receive DeckBridge keys until the device exposes gadget HID (custom kernel / configfs — often root). [ACTION] lines are fallback only.</string>
    <string name="hid_log_diagnose_root_ok_no_hidg">Privileged shell works for this app, but /dev/hidg* is still missing: root does not auto-create HID. Mount the USB gadget (configfs + HID function + bind UDC) outside DeckBridge, then re-open Settings or replug USB. Until hidg0 exists, Windows receives nothing from this path.</string>
    <string name="hid_transport_detail_root_but_no_hidg">Privileged shell (KernelSU/su) is OK for DeckBridge, yet no gadget HID nodes appear. You must bring up the composite gadget in userland (scripts, Magisk/KSU module, or init) so the kernel creates /dev/hidg0 (and hidg1 for media). DeckBridge only writes those device files once they exist.</string>
    <string name="hid_log_diagnose_keyboard_denied">Diagnosis: keyboard HID node exists but this app cannot write it (SELinux/permissions). %1$s</string>
    <string name="hid_log_diagnose_media_only">Diagnosis: keyboard HID works; volume/media skipped — no writable consumer node at %1$s</string>
