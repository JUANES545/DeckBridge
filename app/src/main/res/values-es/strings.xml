    <string name="hid_transport_summary_keyboard_ready">Teclado HID listo</string>
    <string name="hid_transport_summary_full_ready">Teclado + multimedia HID listos</string>
    <string name="hid_transport_summary_error">Error HID</string>
    <string name="hid_transport_detail_default">La salida real al PC cableado requiere USB gadget con HID (root, kernel a medida o configfs). Los teléfonos de serie suelen ofrecer solo MTP/ADB — DeckBridge sigue funcionando; revisa [HID] y [ACTION] en Logcat.</string>
    <string name="hid_transport_paths">Teclado: %1$s · Consumer: %2$s</string>
    <string name="hid_transport_nodes_line">Sondeo: teclado %1$s · consumer %2$s</string>
    <string name="hid_node_state_missing">no existe</string>
    <string name="hid_node_state_writable">escribible</string>
    <string name="hid_node_state_present_blocked">existe, no escribible</string>
    <string name="hid_transport_last_error">Último error: %s</string>
    <string name="hid_log_diagnose_no_nodes">Diagnóstico: no hay nodos /dev/hidg*. El USB a Windows (carga/MTP/ADB) no convierte el teléfono en teclado HID. El PC no recibirá teclas hasta que exista gadget HID (kernel/configfs, a menudo root). Las líneas [ACTION] son solo registro/respaldo.</string>
    <string name="hid_log_diagnose_root_ok_no_hidg">El shell privilegiado funciona para esta app, pero sigue sin existir /dev/hidg*: el root no crea HID solo. Hay que levantar el gadget USB (configfs + función HID + UDC) fuera de DeckBridge; luego refresca Ajustes o reconecta USB. Sin hidg0, Windows no recibe nada por este camino.</string>
    <string name="hid_transport_detail_root_but_no_hidg">KernelSU/su está bien para DeckBridge, pero no aparecen nodos gadget HID. Hay que activar el composite gadget en espacio de usuario (scripts, módulo KSU/Magisk o init) para que el kernel cree /dev/hidg0 (e hidg1 para multimedia). DeckBridge solo escribe en esos dispositivos cuando ya existen.</string>
    <string name="hid_log_diagnose_keyboard_denied">Diagnóstico: el nodo teclado HID existe pero la app no puede escribirlo (SELinux/permisos). %1$s</string>
    <string name="hid_log_diagnose_media_only">Diagnóstico: teclado HID OK; multimedia omitida — no hay nodo consumer escribible en %1$s</string>
